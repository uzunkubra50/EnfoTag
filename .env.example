# Bu dosyayı .env olarak kopyalayıp değerleri kendi ortamına göre doldur:
#   cp .env.example .env
# .env dosyası git'e girmez (.gitignore'da).

# PostgreSQL (Docker)
POSTGRES_DB=barkod
POSTGRES_USER=barkod
POSTGRES_PASSWORD=barkod

# Django
# Üretimde mutlaka uzun, rastgele bir değer kullan:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
